# ──────────────────────────────────────────────────────────────────────────────
# trading_dss — Environment Configuration
# Copy this file to .env and fill in the values.
# .env is git-ignored; never commit secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=trading_dss
# ENVIRONMENT: development | staging | production
ENVIRONMENT=development
DEBUG=false

# ── Logging ───────────────────────────────────────────────────────────────────
# Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# LOG_LOG_DIR=/absolute/path/to/logs   # defaults to data/logs/

# ── Database ──────────────────────────────────────────────────────────────────
# DB_PATH=/absolute/path/trading_dss.db   # defaults to data/db/trading_dss.db
DB_WAL_MODE=true
DB_CONNECTION_POOL_SIZE=5
DB_TIMEOUT_SECONDS=30

# ── Market Hours (IST, HH:MM) ─────────────────────────────────────────────────
MARKET_HOURS_PRE_MARKET_OPEN=09:00
MARKET_HOURS_MARKET_OPEN=09:15
MARKET_HOURS_MARKET_CLOSE=15:30
MARKET_HOURS_POST_MARKET_CLOSE=16:00

# ── Polling Intervals (seconds) ───────────────────────────────────────────────
POLL_PRICE_INTERVAL=60
POLL_OPTIONS_INTERVAL=180
POLL_NEWS_INTERVAL=120
POLL_FII_DII_INTERVAL=900
POLL_VIX_INTERVAL=60

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_NSE_REQUESTS_PER_MINUTE=30
RATE_LIMIT_BSE_REQUESTS_PER_MINUTE=20
RATE_LIMIT_YFINANCE_REQUESTS_PER_MINUTE=60
RATE_LIMIT_NEWS_REQUESTS_PER_MINUTE=30

# ── Signal Thresholds ─────────────────────────────────────────────────────────
THRESHOLD_OI_SPIKE_THRESHOLD=10.0
THRESHOLD_VOLUME_SPIKE_MULTIPLIER=1.5
THRESHOLD_PCR_EXTREME_LOW=0.7
THRESHOLD_PCR_EXTREME_HIGH=1.3
THRESHOLD_VIX_LOW_THRESHOLD=12.0
THRESHOLD_VIX_HIGH_THRESHOLD=20.0
THRESHOLD_VIX_EXTREME_THRESHOLD=30.0
THRESHOLD_SENTIMENT_BULLISH_THRESHOLD=0.3
THRESHOLD_SENTIMENT_BEARISH_THRESHOLD=-0.3
THRESHOLD_RSI_OVERBOUGHT=70.0
THRESHOLD_RSI_OVERSOLD=30.0

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Get bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHHiiJJkkLLmmNNoo
# TELEGRAM_CHAT_ID=-100123456789
TELEGRAM_ALERT_MIN_CONFIDENCE=0.6
